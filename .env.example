# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

# OpenAI — used by speech.transcribe (Whisper STT)
OPENAI_API_KEY=

# Telegram — used by the notify utility and telegram analytics scripts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to 1 to send Telegram notifications after each script run
SCRIPTORIUM_NOTIFY=
