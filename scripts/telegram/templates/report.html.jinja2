<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Chat analytics — {{ a.source.chat_name }}</title>
  <style>{{ css | safe }}</style>
</head>
<body>

{# ============================================================
   PAGE 1 — HERO + HEADLINE NUMBERS + MONTHLY VOLUME CHART
   ============================================================ #}
<section class="page">
  <h1 class="hero">{{ self_name }} &amp; {{ partner_name }}:<br/>How do you chat?</h1>
  <p class="tagline">
    Conversation history from <strong>{{ a.totals.date_range.start }}</strong>
    to <strong>{{ a.totals.date_range.end }}</strong>
    &middot; <strong>{{ "{:,}".format(a.totals.date_range.days) }}</strong> days.
  </p>

  <table class="grid">
    <tr>
      <td>
        <div class="card accent-hero callout">
          <div class="value accent-hero">{{ humanize(a.totals.messages_all_time) }}</div>
          <div class="sublabel">All-time messages exchanged</div>
        </div>
      </td>
      <td>
        <div class="card accent-hero callout">
          <div class="value">{{ a.totals.avg_messages_per_day }}</div>
          <div class="sublabel">Messages per day, on average</div>
        </div>
      </td>
      <td>
        <div class="card accent-hero callout">
          <div class="value">{{ "{:,}".format(a.totals.messages_ytd) }}</div>
          <div class="sublabel">In {{ current_year }} YTD</div>
        </div>
      </td>
    </tr>
  </table>

  <div class="card" style="margin-top: 0.5cm;">
    <h3>Messages per month</h3>
    <div class="chart-frame tall">
      <img src="{{ charts.monthly_volume }}" alt="Monthly volume" />
    </div>
  </div>

  <div class="footer">
    Generated by Scriptorium &middot; timestamps interpreted as the chat's local time.
  </div>
</section>


{# ============================================================
   PAGE 2 — CADENCE & DYNAMICS
   ============================================================ #}
<section class="page">
  <h2 class="section">Conversation dynamics</h2>

  <table class="grid">
    <tr>
      <td style="width: 50%;">
        <div class="card accent-hero">
          <div class="label">Who drives it?</div>
          <p class="punchline">
            <strong style="color: var(--{{ leader_role }});">{{ leader_name }}</strong>
            drives the conversation, sending
            <strong>{{ pct(a.share_by_user[leader_id]) }}</strong> of all messages.
          </p>
          <div class="row-2">
            <div>
              <div class="v self">{{ pct(a.share_by_user[self_id]) }}</div>
              <div class="l">{{ self_name }}</div>
            </div>
            <div>
              <div class="v partner">{{ pct(a.share_by_user[partner_id]) }}</div>
              <div class="l">{{ partner_name }}</div>
            </div>
          </div>
        </div>
      </td>
      <td style="width: 50%;">
        <div class="card">
          <div class="label">Who starts it?</div>
          <p class="punchline">
            <strong style="color: var(--{{ initiator_role }});">{{ initiator_name }}</strong>
            initiated <strong>{{ pct(a.initiation_share[initiator_id]) }}</strong>
            of the {{ "{:,}".format(a.initiation_share.sessions_total) }} sessions.
          </p>
          <p class="figure">
            A "session" = consecutive messages within a 4-hour window.
            Once you go quiet for &gt; 4h, the next message kicks off a new one.
          </p>
        </div>
      </td>
    </tr>
  </table>

  <div class="card" style="margin-top: 0.4cm;">
    <h3>Reply latency</h3>
    <div class="row-2" style="margin-bottom: 6pt;">
      <div>
        <div class="v self">{{ format_seconds(a.reply_latency_seconds[self_id].median) }}</div>
        <div class="l">{{ self_name }} median reply
          <span class="figure" style="display:block; text-transform:none; letter-spacing:0;">
            mean {{ format_seconds(a.reply_latency_seconds[self_id].mean) }},
            p90 {{ format_seconds(a.reply_latency_seconds[self_id].p90) }},
            {{ "{:,}".format(a.reply_latency_seconds[self_id].samples) }} samples
          </span>
        </div>
      </div>
      <div>
        <div class="v partner">{{ format_seconds(a.reply_latency_seconds[partner_id].median) }}</div>
        <div class="l">{{ partner_name }} median reply
          <span class="figure" style="display:block; text-transform:none; letter-spacing:0;">
            mean {{ format_seconds(a.reply_latency_seconds[partner_id].mean) }},
            p90 {{ format_seconds(a.reply_latency_seconds[partner_id].p90) }},
            {{ "{:,}".format(a.reply_latency_seconds[partner_id].samples) }} samples
          </span>
        </div>
      </div>
    </div>
    <div class="chart-frame">
      <img src="{{ charts.reply_latency }}" alt="Reply latency" />
    </div>
  </div>

  <div class="card" style="margin-top: 0.4cm;">
    <div class="label">The "Double-Text" Rate</div>
    <p class="punchline">
      Cringe! <strong style="color: var(--{{ doubletexter_role }});">{{ doubletexter_name }}</strong>
      accounted for <strong>{{ pct(a.double_text_rate[doubletexter_id].share) }}</strong>
      of all double-texts ({{ "{:,}".format(doubletexter_total) }} in total).
    </p>
    <div class="row-2">
      <div>
        <div class="v self">{{ "{:,}".format(a.double_text_rate[self_id].count) }}</div>
        <div class="l">{{ self_name }} double-texts</div>
      </div>
      <div>
        <div class="v partner">{{ "{:,}".format(a.double_text_rate[partner_id].count) }}</div>
        <div class="l">{{ partner_name }} double-texts</div>
      </div>
    </div>
  </div>

  <div class="footer">When you double-text across a 4h gap with no reply in between, it counts.</div>
</section>


{# ============================================================
   PAGE 3 — STYLE & CONTENT
   ============================================================ #}
<section class="page">
  <h2 class="section">When &amp; how you talk</h2>

  <div class="card">
    <h3>Activity heatmap — day of week &times; hour of day</h3>
    <div class="chart-frame">
      <img src="{{ charts.activity_heatmap }}" alt="Activity heatmap" />
    </div>
  </div>

  <table class="grid" style="margin-top: 0.4cm;">
    <tr>
      <td style="width: 50%;">
        <div class="card">
          <div class="label">Message length</div>
          <p class="punchline">
            "I just think it's funny how…"
          </p>
          <div class="row-2">
            <div>
              <div class="v self">{{ a.median_message_length[self_id].chars }}</div>
              <div class="l">{{ self_name }} &middot; {{ a.median_message_length[self_id].words }} words</div>
            </div>
            <div>
              <div class="v partner">{{ a.median_message_length[partner_id].chars }}</div>
              <div class="l">{{ partner_name }} &middot; {{ a.median_message_length[partner_id].words }} words</div>
            </div>
          </div>
          <p class="figure">Median characters per text message (stickers and one-liners excluded).</p>
        </div>
      </td>
      <td style="width: 50%;">
        <div class="card">
          <div class="label">Vocabulary richness</div>
          <p class="punchline">
            Has <strong style="color: var(--{{ vocab_loser_role }});">{{ vocab_loser_name }}</strong>
            ever read a book?
            <strong style="color: var(--{{ vocab_winner_role }});">{{ vocab_winner_name }}</strong>
            uses a richer vocabulary.
          </p>
          <div class="row-2">
            <div>
              <div class="v self">{{ pct(a.vocabulary_richness[self_id].ratio) }}</div>
              <div class="l">{{ self_name }} unique-to-total</div>
            </div>
            <div>
              <div class="v partner">{{ pct(a.vocabulary_richness[partner_id].ratio) }}</div>
              <div class="l">{{ partner_name }} unique-to-total</div>
            </div>
          </div>
        </div>
      </td>
    </tr>
  </table>

  <div class="card" style="margin-top: 0.4cm;">
    <div class="label">External links shared</div>
    <p class="punchline">
      Who needs Reddit when they have
      <strong style="color: var(--{{ linker_role }});">{{ linker_name }}</strong>
      sharing <strong>{{ "{:,}".format(a.external_links.by_user[linker_id]) }}</strong>
      links versus the other side's
      <strong>{{ "{:,}".format(a.external_links.by_user[non_linker_id]) }}</strong>.
    </p>
    <table class="grid">
      <tr>
        <td style="width: 50%;">
          <div class="row-2">
            <div>
              <div class="v self">{{ "{:,}".format(a.external_links.by_user[self_id]) }}</div>
              <div class="l">{{ self_name }} links</div>
            </div>
            <div>
              <div class="v partner">{{ "{:,}".format(a.external_links.by_user[partner_id]) }}</div>
              <div class="l">{{ partner_name }} links</div>
            </div>
          </div>
        </td>
        <td style="width: 50%;">
          <ul class="domain-list">
            {% for domain, n in top_domains %}
            <li><span class="domain">{{ domain }}</span><span class="n">{{ "{:,}".format(n) }}</span></li>
            {% endfor %}
          </ul>
        </td>
      </tr>
    </table>
  </div>

  <div class="footer">Stickers and one-liners are excluded from text-length and vocabulary stats.</div>
</section>


{# ============================================================
   PAGE 4 — STREAKS + WORDS + EMOJIS
   ============================================================ #}
<section class="page">
  <h2 class="section">Words, faves &amp; streaks</h2>

  <div class="card">
    <h3>Word cloud</h3>
    <p class="figure" style="margin-bottom: 4pt;">
      <span style="color: var(--self); font-weight: 700;">{{ self_name }}'s words</span>
      &middot;
      <span style="color: var(--partner); font-weight: 700;">{{ partner_name }}'s words</span>
      &middot;
      <span style="color: var(--shared); font-weight: 700;">shared</span>
    </p>
    <div class="chart-frame">
      <img src="{{ charts.word_cloud }}" alt="Word cloud" />
    </div>
  </div>

  <table class="grid" style="margin-top: 0.4cm;">
    <tr>
      <td style="width: 50%;">
        <div class="card accent-self">
          <div class="podium-title self">{{ self_name }}'s top emojis</div>
          <table class="podium">
            {% for item in (a.top_emojis[self_id] or [])[:5] %}
            <tr>
              <td class="rank">{{ loop.index }}.</td>
              <td class="glyph">{{ item.emoji }}</td>
              <td class="count">{{ "{:,}".format(item.count) }}</td>
            </tr>
            {% else %}
            <tr><td class="rank">—</td><td class="glyph">—</td><td class="count">—</td></tr>
            {% endfor %}
          </table>
        </div>
      </td>
      <td style="width: 50%;">
        <div class="card accent-partner">
          <div class="podium-title partner">{{ partner_name }}'s top emojis</div>
          <table class="podium">
            {% for item in (a.top_emojis[partner_id] or [])[:5] %}
            <tr>
              <td class="rank">{{ loop.index }}.</td>
              <td class="glyph">{{ item.emoji }}</td>
              <td class="count">{{ "{:,}".format(item.count) }}</td>
            </tr>
            {% else %}
            <tr><td class="rank">—</td><td class="glyph">—</td><td class="count">—</td></tr>
            {% endfor %}
          </table>
        </div>
      </td>
    </tr>
  </table>

  <table class="grid streaks-row" style="margin-top: 0.4cm;">
    <tr>
      <td style="width: 50%;">
        <div class="card streak-card">
          <div class="label">Dry spell</div>
          <div class="streak">
            <div class="days">{{ "{:,}".format(a.streaks.longest_silence.days) }}</div>
            <div class="label">days of silence</div>
            <div class="span">
              {{ a.streaks.longest_silence.start }} → {{ a.streaks.longest_silence.end }}
            </div>
          </div>
        </div>
      </td>
      <td style="width: 50%;">
        <div class="card streak-card">
          <div class="label">Hot streak</div>
          <div class="streak">
            <div class="days">{{ "{:,}".format(a.streaks.longest_streak.days) }}</div>
            <div class="label">days non-stop</div>
            <div class="span">
              {{ a.streaks.longest_streak.start }} → {{ a.streaks.longest_streak.end }}
            </div>
          </div>
        </div>
      </td>
    </tr>
  </table>

  <div class="footer">Generated by Scriptorium.</div>
</section>

</body>
</html>
