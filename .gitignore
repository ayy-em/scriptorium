# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.ruff_cache/

# pytest
.pytest_cache/

# LLMs
.claude
CLAUDE.md

# IDEs
.cursor/
.vscode/
.idea/

# Virtual environments
.venv/
uv.lock

# sensitive files
.env
creds.json
tests/telegram/fixtures/chat_export/result.json

# OS
.DS_Store

# Local data — repo-root inputs/ and outputs/ are tracked via .gitkeep,
# their contents are not. Any nested inputs/ outputs/ trees are ignored
# entirely (legacy per-theme directories may linger on disk).
**/inputs/
**/outputs/
!/inputs/
!/outputs/
/inputs/*
/outputs/*
!/inputs/.gitkeep
!/outputs/.gitkeep

past_inputs/
archive/
logs/
*.json
